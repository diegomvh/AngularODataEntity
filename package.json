{
  "name": "angular-odata-entity",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "apigen:trippin": "ng generate angular-odata:apigen --models=true --name=TripPin --metadata='https://services.odata.org/V4/TripPinServiceRW/$metadata'",
    "apigen:northwind": "ng generate angular-odata:apigen --models=true --name=Northwind --metadata='https://services.odata.org/V4/Northwind/Northwind.svc/$metadata'"
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@primeuix/themes": "^2.0.3",
    "@types/geojson": "^7946.0.16",
    "@types/json-schema": "^7.0.15",
    "geojson": "^0.5.0",
    "json-schema": "^0.4.0",
    "primeng": "^21.1.9",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.1",
    "jsdom": "^28.0.0",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.3",
    "vitest": "^4.0.8"
  }
}
